@model IEnumerable<IDGS904ConBase.Models.Maestro>

@{
    ViewBag.Title = "Maestros";
}

<h2>Lista de Maestros</h2>

<p>
    @Html.ActionLink("Nuevo Maestro", "Create")
</p>

<table class="table">
    <tr>
        <th>Nombre</th>
        <th>Apellido Paterno</th>
        <th>Apellido Materno</th>
        <th>Especialidad</th>
        <th>Correo</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Nombre</td>
            <td>@item.Apaterno</td>
            <td>@item.Amaterno</td>
            <td>@item.Especialidad</td>
            <td>@item.Correo</td>
            <td>
                @Html.ActionLink("Editar", "Edit", new { id = item.Id }) |
                @Html.ActionLink("Detalles", "Details", new { id = item.Id }) |
                @Html.ActionLink("Eliminar", "Delete", new { id = item.Id })
            </td>
        </tr>
    }
</table>