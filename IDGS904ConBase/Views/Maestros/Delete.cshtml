@model IDGS904ConBase.Models.Maestro

@{
    ViewBag.Title = "Delete";
}

<h2>Eliminar Maestro</h2>

<h3>¿Está seguro de que desea eliminar este registro?</h3>

<div>
    <hr />

    <dl class="dl-horizontal">

        <dt>Nombre</dt>
        <dd>
            @Html.DisplayFor(model => model.Nombre)
        </dd>

        <dt>Apellido Paterno</dt>
        <dd>
            @Html.DisplayFor(model => model.Apaterno)
        </dd>

        <dt>Apellido Materno</dt>
        <dd>
            @Html.DisplayFor(model => model.Amaterno)
        </dd>

        <dt>Especialidad</dt>
        <dd>
            @Html.DisplayFor(model => model.Especialidad)
        </dd>

        <dt>Correo</dt>
        <dd>
            @Html.DisplayFor(model => model.Correo)
        </dd>

    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(model => model.Id)

        <div class="form-actions no-color">
            <input type="submit" value="Eliminar" class="btn btn-danger" />
            |
            @Html.ActionLink("Regresar", "Index")
        </div>
    }
</div>